{
  "name": "search-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Kambi intent-resolver — extractor + structural eval (Sprint 1).",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server/index.ts",
    "serve": "tsx --env-file=.env src/server/index.ts",
    "eval": "tsx src/eval/run.ts",
    "build:scope:football": "tsx src/resolver/build-scope-index.ts football",
    "build:scope:basketball": "tsx src/resolver/build-scope-index.ts basketball",
    "build:scope:tennis": "tsx src/resolver/build-scope-index.ts tennis",
    "gate:live-menu": "tsx src/eval/live-menu-gate.ts",
    "typecheck": "tsc --noEmit",
    "report:capture": "tsx src/harness-loop/harness-run.ts --batch 002 --capture src/harness-loop/report/002",
    "report:shots": "tsx src/harness-loop/report/generate.ts --batch 002"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hono/node-server": "^2.0.6",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
