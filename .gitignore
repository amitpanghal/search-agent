node_modules/
.env
.DS_Store
*.log
__pycache__/
*.pyc

# Machine-local Claude Code settings/permissions.
.claude/settings.local.json

# Derived vector index (rebuild with `npm run build:index`; needs VOYAGE_API_KEY).
src/resolver/index/

# Transient doc-view generation scratch (Sprint 6): plan + per-batch subagent outputs.
# Durable artifacts are data/football/{criterion-doc-views,doc-views-gen-cache}.json.
.docviews/

# Transient probe-script scratch (dot-prefixed under scripts/: scratch .ts probes + their JSON/txt/out/err dumps).
scripts/.*.ts
scripts/.*.json
scripts/.*.txt
scripts/.*.out
scripts/.*.err
scripts/.trace-out/

# Harness-loop generated artifacts: content-addressed LLM/recall caches + generated query batches.
src/harness-loop/llm-cache/
src/harness-loop/batches/
src/harness-loop/report/

# Data: commit ONLY the built scope indexes the runtime loads
# (data/<sport>/scope-index.json + scope-aliases.json, per scope-catalog.ts). Everything
# else under data/ — raw participant feeds, groups.json, market aliases, related-headline,
# build intermediates — is a build input regenerated by `npm run build:scope:*`, so ignore it.
data/*
!data/football
!data/basketball
!data/tennis
data/football/*
data/basketball/*
data/tennis/*
!data/football/scope-index.json
!data/football/scope-aliases.json
!data/basketball/scope-index.json
!data/basketball/scope-aliases.json
!data/tennis/scope-index.json
!data/tennis/scope-aliases.json

# Intermediate basketball concat blob (regenerate with: npx tsx scripts/basketball/concat-feeds.ts)
data/basketball/basketball_participants_raw.json
# Intermediate tennis concat blob (regenerate with: npx tsx scripts/tennis/concat-feeds.ts)
data/tennis/tennis_participants_raw.json
