# Anthropic API key for the extractor (Haiku). Copy this file to `.env` (gitignored),
# or export ANTHROPIC_API_KEY in your shell. The eval runner reads it via process.env.
ANTHROPIC_API_KEY=

# Voyage API key for grounding's vector tail (voyage-3). Needed by `npm run build:index`
# and by the eval's market grounding (the vector path).
VOYAGE_API_KEY=
